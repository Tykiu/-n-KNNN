from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import supabase

app = FastAPI()

url = "https://YOUR_PROJECT.supabase.co"
key = "YOUR_SUPABASE_KEY"
supabase_client = supabase.create_client(url, key)

# Model cho subject
class Subject(BaseModel):
    name: str
    description: str | None = None

# Model cho tutor request
class TutorRequest(BaseModel):
    subject_id: str   # liên kết tới bảng subjects
    mode: str         # "online" hoặc "offline"
    link_or_address: str
    time: str
    note: str | None = None

# API: Tạo môn học mới
@app.post("/subjects")
def create_subject(subject: Subject):
    response = supabase_client.table("subjects").insert(subject.dict()).execute()
    return response.data

# API: Lấy danh sách môn học
@app.get("/subjects")
def get_subjects():
    response = supabase_client.table("subjects").select("*").execute()
    return response.data

# API: Tạo yêu cầu tìm gia sư
@app.post("/tutor-requests")
def create_tutor_request(request: TutorRequest, user_id: str):
    data = {
        "user_id": user_id,
        "subject_id": request.subject_id,
        "mode": request.mode,
        "link_or_address": request.link_or_address,
        "time": request.time,
        "note": request.note,
        "verified": True
    }
    response = supabase_client.table("tutor_requests").insert(data).execute()
    return response.data

# API: Lấy danh sách yêu cầu tìm gia sư (join với subjects)
@app.get("/tutor-requests")
def get_tutor_requests():
    response = supabase_client.rpc("get_tutor_requests_with_subjects").execute()
    return response.data
